<!DOCTYPE html>

<html lang="pt-BR">

<head>

    <meta charset="UTF-8">

    <meta
        name="viewport"
        content="width=device-width, initial-scale=1.0"
    >

    <title>
        Lista de Clientes
    </title>

    <link
        rel="stylesheet"
        href="/css/style.css"
    >

</head>


<body>

    <h1>
        Lista de Clientes
    </h1>


    <a href="/novo">

        <button>
            Novo Cliente
        </button>

    </a>


    <table>

        <thead>

            <tr>

                <th>ID</th>

                <th>Nome</th>

                <th>Data/Nasc</th>

                <th>CPF</th>

                <th>Endereço</th>

                <th>Telefone</th>

                <th>Email</th>

                <th class="centralizado">
                    Ações
                </th>

            </tr>

        </thead>


        <tbody>

            <% clientes.forEach(cliente => { %>


                <tr>

                    <td>
                        <%= cliente.id %>
                    </td>

                    <td>
                        <%= cliente.nome %>
                    </td>

                    <td>
                        <%= cliente.nascimento %>
                    </td>

                    <td>
                        <%= cliente.cpf %>
                    </td>

                    <td>
                        <%= cliente.endereco %>
                    </td>

                    <td>
                        <%= cliente.telefone %>
                    </td>

                    <td>
                        <%= cliente.email %>
                    </td>


                    <td class="centralizado">


                        <form
                            action="/editar/<%= cliente.id %>"
                            method="GET"
                            style="display:inline;"
                        >

                            <button
                                type="submit"
                                class="editar"
                            >
                                Editar
                            </button>

                        </form>


                        <button
                            type="button"
                            class="excluir"
                            onclick="confirmarExclusao('<%= cliente.id %>')"
                        >
                            Excluir
                        </button>


                    </td>

                </tr>


            <% }) %>

        </tbody>

    </table>


    <div
        id="modalConfirmacao"
        class="modal"
    >

        <div class="modal-content">

            <h2>
                Confirmar exclusão
            </h2>

            <p>
                Deseja realmente excluir este cliente?
            </p>


            <form
                id="formExcluir"
                method="POST"
            >

                <button
                    id="confirmar"
                    type="submit"
                >
                    Confirmar
                </button>


                <button
                    id="cancelar"
                    type="button"
                    onclick="fecharModal()"
                >
                    Cancelar
                </button>

            </form>

        </div>

    </div>


    <script>

        const modal =
            document.getElementById(
                'modalConfirmacao'
            );


        const formExcluir =
            document.getElementById(
                'formExcluir'
            );


        function confirmarExclusao(id) {

            formExcluir.action =
                `/excluir/${id}`;

            modal.style.display =
                'block';

        }


        function fecharModal() {

            modal.style.display =
                'none';

        }


        window.onclick =
            function(event) {

                if (event.target === modal) {

                    fecharModal();

                }

            };

    </script>


</body>

</html>
